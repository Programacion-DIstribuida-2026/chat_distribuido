# Puerto publicado en el host para Mongo (debe coincidir con MONGO_URL).
MONGO_HOST_PORT=37117
# MongoDB (Motor). Mismo puerto que MONGO_HOST_PORT del docker-compose:
MONGO_URL=mongodb://admin:123@127.0.0.1:37117/?authSource=admin
# Opcional (default chat_db). pytest usa chat_test vía tests/conftest.py.
# MONGO_DB_NAME=chat_db

# Redis (async). Opcional: si se omite, /health reportará redis: disabled.
REDIS_URL=redis://127.0.0.1:6379/0

# Auth (JWT HS256). Obligatorio para POST /auth/register y /auth/login (mín. 16 caracteres).
JWT_SECRET=cambia_esto_por_un_secreto_largo_aleatorio
# Opcional: minutos de validez del access token (default 10080 = 7 días).
# JWT_EXPIRE_MINUTES=10080

# CORS: orígenes permitidos separados por coma (front en Vercel). Si se omite, no se añade CORS.
# CORS_ORIGINS=https://chat-five.vercel.app,http://127.0.0.1:3000
